// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "inlay_hints": {
        "show_parameter_hints": false,
        "show_type_hints": false,
        "show_value_hints": false,
        "enabled": true
    },
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)"
    },
    "tab_bar": {
        "show": true
    },
    "toolbar": { "quick_actions": false, "breadcrumbs": true },
    "git": {
        "inline_blame": {
            "enabled": false
        }
    },
    "disable_ai": true,
    "debugger": {
        "timeout": 4000,
        "dock": "right"
    },
    "file_finder": { "modal_max_width": "full" },
    "wsl_connections": [
        {
            "distro_name": "Ubuntu-24.04",
            "user": null,
            "projects": [
                {
                    "paths": ["/home/sander"]
                }
            ]
        }
    ],
    "terminal": {
        "dock": "right",
        "font_family": "FiraCode Nerd Font",
        "font_fallbacks": ["monspace"]
    },
    "project_panel": {
        "auto_reveal_entries": false,
        "auto_fold_dirs": false
    },
    "base_keymap": "VSCode",
    "agent": {
        "enabled": false,
        "button": false,
        "model_parameters": []
    },
    "minimap": {
        "show": "never"
    },
    "active_pane_modifiers": {
        "inactive_opacity": 0.8,
        "border_size": 1
    },
    "buffer_font_fallbacks": ["Consolas", "Courier New", "monospace"],
    "buffer_font_family": "FiraCode Nerd Font",
    "ensure_final_newline_on_save": true,
    "wrap_guides": [120],
    "ui_font_size": 14,
    "buffer_font_size": 13.0,
    "theme": {
        "mode": "dark",
        "light": "GitHub Light",
        "dark": "Tokyo Night"
    },
    "theme_overrides": {
        "VSCode Light+": {
            "border.selected": "#293b5bff",
            "search.active_match_background": "#FFD700AA"
        },
        "Tokyo Night": {
            "border.selected": "#293b5bff",
            "search.active_match_background": "#FFD700AA"
        }
    },
    "languages": {
        "Python": {
            "use_auto_surround": false,
            "use_autoclose": false,
            "jupyter": { "enabled": false },
            "language_servers": [
                "ty",
                "ruff",
                "!basedpyright",
                "!pyright",
                "!pylsp"
            ]
        }
    }
}
